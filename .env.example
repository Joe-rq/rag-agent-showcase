# =====================================================================
# LLM key (config.yaml llm.provider=cloud 时需要, 默认 DeepSeek)
#   取 key: https://platform.deepseek.com/api_keys
#   换厂商: 改 config.yaml 的 llm.providers.cloud.base_url/model
# =====================================================================
LLM_API_KEY=

# =====================================================================
# Embedding 云端 key (仅 config.yaml embedding.provider=cloud 时需要)
# 默认 provider=42model(本地), 不需要此 key
# 推荐 SiliconFlow: BAAI/bge-m3 (免费额度, https://cloud.siliconflow.cn)
# =====================================================================
EMBEDDING_CLOUD_API_KEY=

# =====================================================================
# 本地后端启动:
#   42model: 42model serve --port 11520 -y &
#   ollama:  ollama serve &  (并 ollama pull bge-m3 / qwen2.5:7b)
# =====================================================================
